#include <SPI.h>

#define CS_PIN      10      // Nano: 10, Mega: 53
#define ID_NODO     1      // 1, 2, o 3

volatile uint8_t receivedData = 1;
volatile bool dataReady = false;

void setup() {
  Serial.begin(9600);
  
  pinMode(CS_PIN, INPUT_PULLUP);
  pinMode(MISO, OUTPUT);
  pinMode(MOSI, INPUT);
  pinMode(SCK, INPUT);
  
  // Configurar SPI como esclavo
  SPCR = (1 << SPE) | (1 << CPHA) | (1 << CPOL);
  SPCR &= ~(1 << MSTR);
  SPDR = 0x00;
  
  SPI.attachInterrupt();
  
  Serial.print("Nodo ");
  Serial.print(ID_NODO);
  Serial.println(" listo (modo polling)");
}

ISR(SPI_STC_vect) {
  if(digitalRead(CS_PIN) == LOW) {
    receivedData = SPDR;
    dataReady = true;
  }
}

void loop() {
  if(dataReady) {
    dataReady = false;
    
    uint8_t data = receivedData;
    
    Serial.print("[Nodo ");
    Serial.print(ID_NODO);
    Serial.print("] Recibido: 0x");
    if(data < 0x10) Serial.print("0");
    Serial.println(data, HEX);
    
    // Reenviar al siguiente nodo
    if(ID_NODO == 3) {
      // Último nodo: devuelve incremento
      SPDR = data + 1;
    } else {
      // Reenviar el mismo dato
      SPDR = data;
    }
    
    // Esperar a que el dato se envíe
    delayMicroseconds(100);
  }
  delay(1);
} 
