// ============================================================
//   LOOPBACK SPI OFICIAL
//   Conecta D11 a D12
// ============================================================

#include <SPI.h>

void setup() {
  Serial.begin(9600);
  
  Serial.println("========================================");
  Serial.println("   LOOPBACK SPI OFICIAL");
  Serial.println("========================================");
  Serial.println("Conecta D11 a D12");
  Serial.println("========================================");
  
  // Inicializar SPI como MAESTRO
  SPI.begin();
  SPI.setDataMode(SPI_MODE0);
  SPI.setBitOrder(MSBFIRST);
  SPI.setClockDivider(SPI_CLOCK_DIV16);
}

void loop() {
  uint8_t enviado = 0x55;
  uint8_t recibido;
  
  // Enviar y recibir (el maestro genera el reloj)
  recibido = SPI.transfer(enviado);
  
  Serial.print("Env: 0x");
  Serial.print(enviado, HEX);
  Serial.print(" Rec: 0x");
  Serial.println(recibido, HEX);
  
  if(recibido == enviado) {
    Serial.println(">>> SPI FUNCIONA!");
  } else {
    Serial.println(">>> ERROR - Revisa conexion D11-D12");
  }
  
  Serial.println("------------------------");
  delay(2000);
}
